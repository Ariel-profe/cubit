---
import type { NotebooksWithImages } from "@/interfaces";
import { ProductCard } from "./ProductCard";

interface Props {
  products: NotebooksWithImages[];
}

const { products } = Astro.props;
---

<div
  class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 place-items-center mt-10 lg:mt-20"
>
  {products.map((product) => <ProductCard product={product} client:load />)}
</div>
